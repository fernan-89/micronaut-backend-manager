# ==============================================================================
# 🚀 THINKLAB MANAGER - CORE ENTERPRISE GITIGNORE
# ==============================================================================

# 📦 Java & Compiled Artifacts
# ------------------------------------------------------------------------------
*.class
*.pyc
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*

# 🏗️ Gradle Build Tool & Micronaut Outputs
# ------------------------------------------------------------------------------
.gradle/
build/
bin/
out/
.micronaut-cli.yml.tmp
**/build/
**/out/

# Bloqueios específicos para travar arquivos gerados em execução pelo Gradle Daemon
.gradle/*
*.lock
*.probe
.gradle/buildOutputCleanup/
.gradle/file-system.probe

# 💻 IDEs and Editors Configuration (IntelliJ IDEA, VS Code, Eclipse)
# ------------------------------------------------------------------------------
.idea/
*.iml
*.iws
*.ipr
.vscode/
.classpath
.project
.settings/
.factorypath

# 🧪 Postman & Newman Local Execution Security
# ------------------------------------------------------------------------------
# Impede o commit acidental de relatórios gerados pelo htmlextra
reports/
*.html

# BLOQUEIO CRÍTICO: Protege contra vazamento de tokens e hashes gerados em runtime.
# Permite apenas os modelos de coleções e ambientes padrões do repositório.
PostMan-Collection/*.data.json
PostMan-Collection/*_working_copy.json
PostMan-Collection/*.bak

# 📝 System Logs & Temporary Dumps
# ------------------------------------------------------------------------------
*.log
logs/
*.tmp
*.bak
*.swp
.DS_Store
Thumbs.db